# ─── NightsWatch — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL password (used by all services that connect to the DB)
POSTGRES_PASSWORD=change-me-strong-password

# JWT signing secret — must be identical in auth-service and api-gateway.
# Generate a secure value:  openssl rand -base64 48
# The value must be base64-encoded and at least 256 bits (32 bytes) long.
AUTH_JWT_SECRET=change-me-base64-encoded-secret

# Your public domain (used for SSL certificate)
DOMAIN=yourdomain.com
